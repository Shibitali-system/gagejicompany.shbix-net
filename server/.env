PORT=4000

# AirPay merchant credentials
AIRPAY_MERCHANT_ID=456
AIRPAY_USERNAME=your_username
AIRPAY_PASSWORD=your_password
AIRPAY_SECRET=your_secret            # used to compute privatekey
AIRPAY_ENCRYPTION_KEY=a197b462cb0350a093f34996f698dc94  # secretKey in PHP example

# AirPay token (if required in query param)
AIRPAY_TOKEN=your_access_token

# Your site urls
SUCCESS_URL=https://your-site.com/payment-success
CANCEL_URL=https://your-site.com/payment-cancel
CALLBACK_URL=https://your-server.com/api/airpay/callback
